# ==============================================================
# KrishiAI — .gitignore
# Python 3.11+  |  FastAPI / APScheduler / Redis / pytest
# ==============================================================

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Python Cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / Build ──────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── pytest / Coverage ────────────────────────────────────────
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Type Checking ────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
pyrightconfig.json

# ── Jupyter / IPython ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Redis ────────────────────────────────────────────────────
dump.rdb
*.rdb
appendonly.aof

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────
ehthumbs.db
desktop.ini
