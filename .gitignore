# AgriSense — Python + ML project .gitignore
# ==============================================================
# Trace Agricultural AI System — .gitignore
# Python 3.11+ | FastAPI | LangGraph | PostgreSQL | pytest
# ==============================================================

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
.gemini/

# ─── Distribution / Build ──────────────────────────────────────
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# ─── Virtual environments ─────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ─── Secrets & Environment variables ─────────────────────────
.env.local
.env.production
.env.staging
*.env
! .env.example
secrets.yaml
secrets.json
*.pem
*.key

# ─── Jupyter notebooks checkpoints ───────────────────────────
.ipynb_checkpoints
*.ipynb

# ─── Databases / Storage ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3
agri.db
agri.db-journal
dump.rdb
*.rdb
appendonly.aof
docker/data/
/data/*.db

# ─── Model artifacts (large binaries) ─────────────────────────
# Commit only small reference models if needed.
# For large production models, use DVC or Git LFS.
configs/scaler.pkl
configs/_smoke_test*
configs/_test_*
mlruns/
model_weights/
models/**/*.h5
models/**/*.pth
models/**/*.bin
models/**/*.pt
models/**/*.onnx
models/**/*.tflite
artifacts/
.dvc/config.local

# ─── Data & Satellite Imagery ──────────────────────────────────
data/raw/
data/processed/
data/geotiffs/
data/features/
data/satellite_tiles/
!data/sample/
!data/.gitkeep
preprocessing/alerts/*.geojson

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ─── Frontend (React/Vite/Next.js) ──────────────────────────────
node_modules/
frontend/dashboard/dist/
frontend/dashboard/build/
.next/
.nuxt/
.vercel/
.npm
package-lock.json
yarn.lock
pnpm-lock.yaml
.eslintcache
*.tsbuildinfo

# ─── Project Specifics ────────────────────────────────────────
test_outputs/
.python-version

# ─── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── OS ───────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
.hypothesis/

# ─── Rasterio / GDAL temp files ──────────────────────────────
*.tif.aux.xml
*.ovr

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
scratch/
