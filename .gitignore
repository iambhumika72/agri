# ==============================================================
# KrishiAI — .gitignore
# Python 3.11+  |  FastAPI / APScheduler / Redis / pytest
# ==============================================================

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Python Cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / Build ──────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── pytest / Coverage ────────────────────────────────────────
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Type Checking ────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
pyrightconfig.json

# ── Jupyter / IPython ────────────────────────────────────────
.ipynb_checkpoints/
# *.ipynb  <-- Removed to track development notebooks

# ── Redis ────────────────────────────────────────────────────
dump.rdb
*.rdb
appendonly.aof

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Data & Satellite Imagery ──────────────────────────────────
data/raw/
data/processed/
data/satellite_tiles/
!data/sample/

# ── ML Models & Artifacts ─────────────────────────────────────
mlruns/
models/**/*.h5
models/**/*.pth
models/**/*.bin
models/**/*.pt
models/**/*.onnx
models/**/*.tflite
artifacts/
.dvc/config.local

# ── Frontend (React/Vite/Next.js) ──────────────────────────────
node_modules/
frontend/dashboard/dist/
frontend/dashboard/build/
.next/
.nuxt/
.vercel/
.npm
.eslintcache
*.tsbuildinfo
# package-lock.json (Best practice to commit this for consistent builds)
yarn.lock
pnpm-lock.yaml

# ── Agri Project Specifics ──────────────────────────────────
agri.db
agri.db-journal
test_outputs/
.python-version

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────
ehthumbs.db
desktop.ini
