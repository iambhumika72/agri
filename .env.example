# AgriSense Environment Variables Template
# Copy this to .env and fill in real values. NEVER commit .env to Git.

# ─── Gemini (Google AI) ───────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_key_here

# ─── Twilio (SMS delivery) ────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ─── Google Earth Engine ─────────────────────────────────────
GEE_SERVICE_ACCOUNT=your_service_account@project.iam.gserviceaccount.com
GEE_KEY_FILE=configs/gee_service_key.json

# ─── Application ──────────────────────────────────────────────
AGRISENSE_ENV=development         # development | staging | production
AGRISENSE_SECRET_KEY=change-this-in-production
TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Pipeline ────────────────────────────────────────────────
PIPELINE_VERSION=1.0.0
